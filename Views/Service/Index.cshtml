@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<ServiceVM>
@{
    ViewData["Title"] = "My Services";
}

<div class="container py-4">
    <div class="sp-page-header">
        <h2><i class="fas fa-briefcase"></i> My Services</h2>
        <a asp-action="Create" class="btn btn-sp-primary">
            <i class="fas fa-plus"></i> Add Service
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var service in Model)
            {
                <div class="col-md-4 col-sm-6" id="service-@service.Id">
                    <div class="sp-card">
                        @if (!string.IsNullOrEmpty(service.ImageUrl))
                        {
                            <img src="@service.ImageUrl" class="card-img-top" alt="@service.Title" />
                        }
                        else
                        {
                            <div class="sp-card-img-placeholder">
                                <i class="fas fa-briefcase"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@service.Title</h5>
                            <p class="card-text">
                                @if (service.Description?.Length > 80)
                                {
                                    @service.Description.Substring(0, 80)<text>...</text>
                                }
                                else
                                {
                                    @service.Description
                                }
                            </p>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="sp-price">@service.BasePrice.ToString("C")</span>
                                @if (service.IsAvailable)
                                {
                                    <span class="sp-available"><i class="fas fa-check-circle"></i></span>
                                }
                                else
                                {
                                    <span class="sp-unavailable"><i class="fas fa-times-circle"></i></span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(service.CategoryName))
                            {
                                <small class="text-muted"><i class="fas fa-tag"></i> @service.CategoryName</small>
                            }

                            <div class="d-flex gap-2 mt-3">
                                <a asp-action="Edit" asp-route-serviceId="@service.Id"
                                   class="btn btn-sp-warning btn-sp-sm flex-grow-1">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-serviceId="@service.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this service?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sp-danger btn-sp-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 d-flex justify-content-center">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" },
                UlElementClasses = new string[] { "pagination justify-content-center" }
            })
        </div>
    }
    else
    {
        <div class="sp-empty-state" > 
            <i class="fas fa-briefcase d-block"></i>
            <h4>No services yet</h4>
            <p>Start by adding your first service!</p>
        </div>
    }
</div>

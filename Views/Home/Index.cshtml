@{
    ViewData["Title"] = "Home";
    var categories = ViewBag.Categories as IEnumerable<CategoryDto>;
    var services = ViewBag.LatestServices as IEnumerable<ServiceDto>;
}

<!-- ===== Hero Section ===== -->
<div class="sp-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1><i class="fas fa-bolt"></i> Smart Platform</h1>
                <p>Find the best services from top providers. Browse categories, request services, and manage everything in one place.</p>
                <a asp-controller="Category" asp-action="Index" class="btn btn-sp-white btn-lg">
                    <i class="fas fa-th-large"></i> Browse Categories
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">

    <!-- ===== Categories Section ===== -->
    @if (categories != null && categories.Any())
    {
        <h2 class="sp-section-title"><i class="fas fa-th-large"></i> Categories</h2>
        <div class="row g-4 mb-5">
            @foreach (var category in categories.Take(6))
            {
                <div class="col-md-4 col-sm-6">
                    <partial name="_CategoryCard" model="category" />
                </div>
            }
        </div>

        @if (categories.Count() > 6)
        {
            <div class="text-center mb-5">
                <a asp-controller="Category" asp-action="Index" class="btn btn-sp-outline">
                    View All Categories <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        }
    }

    <!-- ===== Latest Services Section ===== -->
    @if (services != null && services.Any())
    {
        <h2 class="sp-section-title"><i class="fas fa-briefcase"></i> Latest Services</h2>
        <div class="row g-4 mb-5">
            @foreach (var service in services.Take(6))
            {
                <div class="col-md-4 col-sm-6">
                    <partial name="_ServiceCard" model="service" />
                </div>
            }
        </div>
    }
    else
    {
        <div class="sp-empty-state">
            <i class="fas fa-box-open d-block"></i>
            <h4>No services available yet</h4>
            <p>Services will appear here once providers add them.</p>
        </div>
    }

</div>

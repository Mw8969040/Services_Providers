@model SmartPlatform.Application.DTOs.CustomerProfileDto
@{
    ViewData["Title"] = "My Profile (Customer)";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
                <div class="card-header bg-primary py-4 text-white">
                    <h2 class="mb-0 px-3"><i class="fas fa-user-circle me-2"></i> @Model.FullName Profile</h2>
                </div>
                <div class="card-body p-5 bg-white">
                    <form asp-action="UpdateCustomer" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="row g-5">
                            <div class="col-lg-4 text-center border-end">
                                <div class="sp-profile-image-wrapper mx-auto position-relative" style="width: 180px; height: 180px;">
                                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                                    {
                                        <img src="@Model.ProfilePictureUrl" id="profileImagePreview" alt="Profile" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%; border: 5px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.1);" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center h-100" id="profileImagePreviewPlaceholder" style="border-radius: 50%; border: 5px solid #fff; width: 100%; height: 100%;">
                                            <i class="fas fa-user fa-4x text-muted"></i>
                                        </div>
                                    }
                                    <!-- Camera Icon Trigger -->
                                    <div class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 shadow" 
                                         style="cursor: pointer; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border: 3px solid #fff;"
                                         onclick="document.getElementById('imageFile').click();">
                                        <i class="fas fa-camera"></i>
                                    </div>
                                </div>
                                <!-- Hidden File Input -->
                                <input type="file" name="imageFile" id="imageFile" style="display:none;" onchange="previewImage(this);" />

                                <div class="mt-4 text-start">
                                    <label asp-for="ProfilePictureUrl" class="form-label small text-muted text-uppercase fw-bold">Or paste Image URL</label>
                                    <input asp-for="ProfilePictureUrl" class="form-control form-control-sm border-0 bg-light" placeholder="https://..." />
                                </div>
                            </div>

                            <div class="col-lg-8">
                                <div class="mb-4">
                                    <label asp-for="FullName" class="form-label text-muted text-uppercase fw-bold small">Full Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0"><i class="fas fa-id-card text-muted"></i></span>
                                        <input asp-for="FullName" class="form-control border-0 bg-light p-3" placeholder="Enter your full name" />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Address" class="form-label text-muted text-uppercase fw-bold small">Address / Contact Location</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                        <textarea asp-for="Address" class="form-control border-0 bg-light p-3" rows="3" placeholder="Where should providers reach you?"></textarea>
                                    </div>
                                    <span asp-validation-for="Address" class="text-danger small"></span>
                                </div>

                                <div class="d-grid mt-5">
                                    <button type="submit" class="btn btn-primary btn-lg p-3 shadow-sm border-0" style="border-radius: 12px; transition: all 0.3s;">
                                        <i class="fas fa-save me-2"></i> Update My Profile
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f4f7f6; }
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        border: 1px solid #0d6efd !important;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
    }
</style>

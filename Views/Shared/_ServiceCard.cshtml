@* --- Partial View: Service Card --- *@
@* بيعرض خدمة واحدة كـ Card *@
@model ServiceDto

<div class="sp-card">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" />
    }
    else
    {
        <div class="sp-card-img-placeholder">
            <i class="fas fa-briefcase"></i>
        </div>
    }
    <div class="card-body">
        <h5 class="card-title">@Model.Title</h5>
        <p class="card-text">
            @if (Model.Description?.Length > 100)
            {
                @Model.Description.Substring(0, 100)<text>...</text>
            }
            else
            {
                @Model.Description
            }
        </p>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="sp-price">@Model.BasePrice.ToString("C")</span>
            @if (Model.IsAvailable)
            {
                <span class="sp-available"><i class="fas fa-check-circle"></i> Available</span>
            }
            else
            {
                <span class="sp-unavailable"><i class="fas fa-times-circle"></i> Unavailable</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <div class="mt-2">
                <small class="text-muted"><i class="fas fa-tag"></i> @Model.CategoryName</small>
            </div>
        }

        <div class="mt-3">
            <a asp-controller="Service" asp-action="Details" asp-route-id="@Model.Id"
               class="btn btn-sp-primary btn-sm w-100">
                <i class="fas fa-eye"></i> View Details
            </a>
        </div>
    </div>
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Platform</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome (أيقونات) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- X.PagedList CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== Navbar ===== -->
    <nav class="navbar navbar-expand-lg sp-navbar sticky-top">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-bolt"></i> Smart Platform
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <!-- Home — للجميع -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>

                    <!-- Categories — للجميع -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Category" asp-action="Index">
                            <i class="fas fa-th-large"></i> Categories
                        </a>
                    </li>

                    @if (User.IsInRole("Provider"))
                    {
                        <!-- خدماتي — للـ Provider فقط -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Service" asp-action="Index">
                                <i class="fas fa-briefcase"></i> My Services
                            </a>
                        </li>
                        <!-- الطلبات الواردة — للـ Provider فقط -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ServiceRequest" asp-action="Index">
                                <i class="fas fa-inbox"></i> Requests
                            </a>
                        </li>
                        <!-- بروفايلي — للـ Provider فقط -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                <i class="fas fa-user-gear"></i> My Profile
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Customer"))
                    {
                        <!-- طلباتي — للـ Customer فقط -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ServiceRequest" asp-action="MyRequests">
                                <i class="fas fa-shopping-bag"></i> My Requests
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                <i class="fas fa-user-circle"></i> My Profile
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Provider"))
                    {
                        <!-- الإحصائيات — للـ Admin والـ Provider -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="fas fa-chart-line"></i> Dashboard
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <!-- لوحة التحكم — للـ Admin فقط -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-users-cog"></i> Users
                            </a>
                        </li>
                    }
                </ul>

                <!-- Login/Logout -->
                <ul class="navbar-nav">
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </div>
    </nav>

    <!-- ===== Toast Container (للإشعارات) ===== -->
    <div id="toastContainer" class="sp-toast-container"></div>

    <!-- ===== TempData Messages ===== -->
    @if (TempData["Success"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('@TempData["Success"]', 'success');
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showToast('@TempData["Error"]', 'error');
            });
        </script>
    }

    <!-- ===== Main Content ===== -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- ===== Footer ===== -->
    <footer class="sp-footer">
        <div class="container">
            <p class="mb-0">
                &copy; 2026 <strong>Smart Platform</strong> — All rights reserved
            </p>
        </div>
    </footer>

    <!-- ===== Generic Modal (يُستخدم للـ Create/Edit) ===== -->
    <div class="modal fade" id="spModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="spModalTitle">Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="spModalBody">
                    <!-- المحتوى يتحمل هنا بـ AJAX -->
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Confirm Delete Modal ===== -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white" style="border-radius: 12px 12px 0 0;">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="sp-delete-warning">
                        <i class="fas fa-trash-alt"></i>
                        <p>Are you sure you want to delete this item?</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Scripts ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

@using Microsoft.AspNetCore.Identity
@using SmartPlatform.Domain.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@* --- Login/Logout Links في الـ Navbar --- *@

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link">
            <i class="fas fa-user-circle"></i> Hello, @User.Identity?.Name!
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link border-0">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus"></i> Register
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-sign-in-alt"></i> Login
        </a>
    </li>
}

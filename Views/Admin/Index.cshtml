@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SmartPlatform.Application.DTOs.UserDto>
@{
    ViewData["Title"] = "User Management";
}

@inject Microsoft.AspNetCore.Identity.UserManager<SmartPlatform.Domain.Entities.ApplicationUser> UserManager

<div class="container py-4">
    <div class="sp-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <h2 class="mb-0"><i class="fas fa-users-cog"></i> User Management</h2>
        
        <partial name="_AjaxSearch" model='new Dictionary<string, string> { { "Name", "Name" }, { "Email", "Email" }, { "Phone", "Phone" } }' />
    </div>

    <div id="tableContainer">
        <partial name="_UserTablePartial" model="Model" />
    </div>
</div>

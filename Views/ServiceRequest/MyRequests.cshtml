@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<ServiceRequestDto>
@{
    ViewData["Title"] = "My Requests";
}

<div class="container py-4">
    <div class="sp-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <h2 class="mb-0"><i class="fas fa-shopping-bag"></i> My Requests</h2>
        
        <partial name="_AjaxSearch" model='new Dictionary<string, string> { { "Service", "Service Title" } }' />
    </div>

    <div id="tableContainer">
        <partial name="_OutgoingRequestsPartial" model="Model" />
    </div>
</div>

@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<ServiceRequestDto>
@{
    ViewData["Title"] = "Incoming Requests";
}

<div class="container py-4">
    <div class="sp-page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <h2 class="mb-0"><i class="fas fa-inbox"></i> Incoming Requests</h2>
        
        <partial name="_AjaxSearch" model='new Dictionary<string, string> { { "Service", "Service Title" }, { "Customer", "Customer Name" }, { "Phone", "Customer Phone" } }' />
    </div>

    <div id="tableContainer">
        <partial name="_IncomingRequestsPartial" model="Model" />
    </div>
</div>

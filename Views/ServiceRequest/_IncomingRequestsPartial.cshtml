@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SmartPlatform.Application.DTOs.ServiceRequestDto>

@if (Model != null && Model.Any(r => r.requestStatus == SmartPlatform.Application.DTOs.Enums.RequestStatusDto.Pending))
{
    var latest = Model.First(r => r.requestStatus == SmartPlatform.Application.DTOs.Enums.RequestStatusDto.Pending);
    <div class="alert alert-primary d-flex justify-content-between align-items-center mb-4 shadow-sm border-0" style="border-left: 5px solid var(--primary-dark) !important; border-radius: var(--radius-sm); background-color: var(--primary-light);">
        <div>
            <i class="fas fa-headset me-2 text-primary"></i> 
            <strong>Newest Request:</strong> 
            <a asp-controller="Profile" asp-action="CustomerPublicProfile" asp-route-userId="@latest.CustomerId" class="text-primary text-decoration-none fw-bold">
                @latest.CustomerName
            </a>
            <span class="badge bg-white text-secondary border ms-2">
                <i class="fas fa-info-circle me-1"></i> Click name for details
            </span>
        </div>
        <a href="tel:@latest.CustomerPhoneNumber" class="btn btn-sp-primary btn-sp-sm">
            <i class="fas fa-phone"></i> Call Customer
        </a>
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="sp-table">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Service</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr id="request-@request.Id">
                        <td>@request.Id</td>
                        <td><strong>@request.ServiceTitle</strong></td>
                        <td>
                            <a asp-controller="Profile" asp-action="CustomerPublicProfile" asp-route-userId="@request.CustomerId" class="text-primary text-decoration-none fw-bold">
                                @request.CustomerName
                            </a>
                        </td>
                        <td>@request.RequestDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="sp-price">@request.TotalPrice.ToString("C")</span></td>
                        <td>
                            <partial name="_StatusBadge" model="request.requestStatus" />
                        </td>
                        <td>
                            @if (request.requestStatus == SmartPlatform.Application.DTOs.Enums.RequestStatusDto.Pending)
                            {
                                <form asp-action="Accept" asp-route-requestId="@request.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sp-success btn-sp-sm" title="Accept">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </form>
                                <form asp-action="Reject" asp-route-requestId="@request.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sp-danger btn-sp-sm" title="Reject">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            }
                            else if (request.requestStatus == SmartPlatform.Application.DTOs.Enums.RequestStatusDto.Accepted)
                            {
                                <form asp-action="Complete" asp-route-requestId="@request.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sp-primary btn-sp-sm" title="Mark as Complete">
                                        <i class="fas fa-check-double"></i> Complete
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 d-flex justify-content-center">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchBy = ViewBag.SearchBy, searchTerm = ViewBag.SearchTerm }), new PagedListRenderOptions {
            LiElementClasses = new string[] { "page-item" },
            PageClasses = new string[] { "page-link" },
            UlElementClasses = new string[] { "pagination justify-content-center" }
        })
    </div>
}
else
{
    <div class="sp-empty-state">
        <i class="fas fa-inbox d-block"></i>
        <h4>No requests yet</h4>
        <p>Incoming requests from customers will appear here.</p>
    </div>
}
